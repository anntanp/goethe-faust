# Goethe-Faust stack configuration.
# Copy to config.env and edit — config.env is gitignored.

# --- Ports ---

# QLever raw SPARQL endpoint
QLEVER_PORT=7030

# SHMARQL UI + SPARQL (backed by QLever)
SHMARQL_PORT=7032

# --- Input data ---

# Path to a single .nt file, or a directory containing .nt files.
# Relative paths are resolved from the goethe-faust/ directory.
NT_INPUT=output/ddbedm-goethe-faust.nt

# --- Directories ---

# QLever binary index (persisted across restarts)
INDEX_DIR=data/qlever-index

# Log output from docker compose logs
LOG_DIR=data/logs

# --- QLever tuning ---

# Memory cap for the QLever server process
QLEVER_MEMORY=4GB

# Base name for QLever index files (change if indexing a different dataset)
INDEX_NAME=goethe-faust
